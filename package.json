{
  "name": "@f4ah6o/responsible",
  "version": "0.1.0",
  "description": "型付き Activity と責任境界による業務プロセスモデルのリファレンス実装。",
  "license": "MIT",
  "files": [
    "dist-lib",
    "README.md",
    "LICENSE",
    "CHANGES.md"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist-lib/index.d.ts",
      "default": "./dist-lib/index.js"
    }
  },
  "scripts": {
    "dev": "node tools/sync-schemas.mjs && vp dev",
    "build": "node tools/sync-schemas.mjs && vp build",
    "build:lib": "tsc -p tsconfig.lib.json",
    "sync-schemas": "node tools/sync-schemas.mjs",
    "check": "vp check",
    "format": "vp format",
    "format:check": "vp check",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import ./tools/test-register.mjs --test \"src/__tests__/**/*.test.ts\"",
    "preview": "vp preview",
    "lint:pkg": "publint && attw --pack . --profile esm-only",
    "prepack": "pnpm run build:lib"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.4",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@xyflow/react": "^12.11.1",
    "ajv": "^8.20.0",
    "html-to-image": "^1.11.13",
    "publint": "^0.3.21",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "~6.0.3",
    "vite-plus": "^0.2.1"
  },
  "engines": {
    "node": ">=22.18.0"
  },
  "packageManager": "pnpm@10.14.0"
}
